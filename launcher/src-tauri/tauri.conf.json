{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Aegis",
  "version": "0.1.7",
  "identifier": "com.aegis.settings",
  "build": {
    "frontendDist": "../src"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "main",
        "url": "welcome/index.html",
        "title": "Aegis",
        "width": 600,
        "height": 620,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "transparent": true,
        "center": true
      },
      {
        "label": "auth",
        "url": "auth/signin.html",
        "title": "Aegis Sign In",
        "width": 500,
        "height": 540,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "public.app-category.productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/aegis"
    ],
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": "./Entitlements.plist"
    }
  }
}
