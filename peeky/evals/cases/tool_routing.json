{
  "_doc": "Tool-routing eval cases. Each case feeds a transcript to the classifier and compares the actual Intent to expected_intent. The model never sees expected_intent. Add or edit cases freely; just keep ids unique. Run with: cargo run --release --example eval_tool_routing",
  "cases": [
    {
