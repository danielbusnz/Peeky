{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Peeky",
  "version": "0.1.10",
  "identifier": "com.peeky.settings",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "windows": [
      {
        "label": "onboarding",
        "url": "onboarding/index.html",
        "title": "Peeky",
        "width": 600,
        "height": 620,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": false,
        "skipTaskbar": true,
        "transparent": true,
        "center": true
      },
      {
        "label": "settings",
        "url": "settings-ui/signin.html",
        "title": "Peeky",
        "width": 500,
        "height": 540,
        "resizable": false,
        "fullscreen": false,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "transparent": true,
        "visible": false,
        "focus": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "category": "public.app-category.productivity",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/peeky"
    ],
    "resources": {
      "../../models/routelet/embedder.onnx": "models/routelet/embedder.onnx",
      "../../models/routelet/head.json": "models/routelet/head.json",
      "../../models/routelet/tokenizer.json": "models/routelet/tokenizer.json"
    },
    "macOS": {
      "minimumSystemVersion": "10.13",
      "entitlements": "./Entitlements.plist"
    }
  }
}
